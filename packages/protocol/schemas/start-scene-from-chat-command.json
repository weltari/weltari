{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "world_id": {
      "type": "string",
      "minLength": 1
    },
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "character_id": {
      "type": "string",
      "minLength": 1
    },
    "scene_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "place": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "premise": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    }
  },
  "required": [
    "world_id",
    "actor_id",
    "character_id",
    "scene_id",
    "title",
    "place"
  ],
  "additionalProperties": false
}

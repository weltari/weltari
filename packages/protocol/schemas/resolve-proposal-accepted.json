{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "accepted": {
      "type": "boolean",
      "const": true
    },
    "proposal_id": {
      "type": "string",
      "minLength": 1
    },
    "resolution": {
      "type": "string",
      "enum": [
        "approved",
        "rejected"
      ]
    },
    "applied": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": [
    "accepted",
    "proposal_id",
    "resolution",
    "applied"
  ],
  "additionalProperties": false
}

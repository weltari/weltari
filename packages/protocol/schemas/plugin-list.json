{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "provenance": {
            "type": "object",
            "properties": {
              "source_url": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "minLength": 64,
                "maxLength": 64
              }
            },
            "required": [
              "source_url",
              "sha256"
            ],
            "additionalProperties": false
          },
          "themes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "components": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "connectors": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": [
          "name",
          "version",
          "provenance",
          "themes",
          "components",
          "connectors"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "plugins"
  ],
  "additionalProperties": false
}

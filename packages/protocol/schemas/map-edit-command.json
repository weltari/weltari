{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "world_id": {
      "type": "string",
      "minLength": 1
    },
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "points": {
      "minItems": 3,
      "maxItems": 128,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "x": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "y": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": [
          "x",
          "y"
        ],
        "additionalProperties": false
      }
    },
    "intent": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    }
  },
  "required": [
    "world_id",
    "actor_id",
    "points",
    "intent",
    "request_id"
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "world_id": {
      "type": "string",
      "minLength": 1
    },
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "proposal_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "resolution": {
      "type": "string",
      "enum": [
        "approved",
        "rejected"
      ]
    }
  },
  "required": [
    "world_id",
    "actor_id",
    "proposal_id",
    "resolution"
  ],
  "additionalProperties": false
}

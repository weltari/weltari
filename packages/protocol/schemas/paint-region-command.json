{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "world_id": {
      "type": "string",
      "minLength": 1
    },
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "image_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "region": {
      "type": "object",
      "properties": {
        "x": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "y": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "width": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 4096
        },
        "height": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 4096
        }
      },
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "additionalProperties": false
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    }
  },
  "required": [
    "world_id",
    "actor_id",
    "image_id",
    "region",
    "request_id"
  ],
  "additionalProperties": false
}

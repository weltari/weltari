{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "accepted": {
      "type": "boolean",
      "const": true
    },
    "outcome": {
      "type": "string",
      "enum": [
        "instantiated",
        "join"
      ]
    },
    "marker_id": {
      "type": "string",
      "minLength": 1
    },
    "scene_id": {
      "type": "string",
      "minLength": 1
    },
    "sublocation_id": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "accepted",
    "outcome",
    "marker_id",
    "scene_id",
    "sublocation_id"
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "dev.gauges"
        },
        "loop_p99_ms": {
          "type": "number",
          "minimum": 0
        },
        "rss_mb": {
          "type": "number",
          "minimum": 0
        },
        "degraded": {
          "type": "boolean"
        }
      },
      "required": [
        "type",
        "loop_p99_ms",
        "rss_mb",
        "degraded"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "dev.tool_call"
        },
        "turn_id": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "input_json": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "turn_id",
        "tool",
        "input_json"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "dev.tool_rejected"
        },
        "turn_id": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "gate": {
          "type": "string",
          "enum": [
            "schema",
            "state"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "type",
        "turn_id",
        "tool",
        "gate",
        "reason"
      ],
      "additionalProperties": false
    }
  ]
}

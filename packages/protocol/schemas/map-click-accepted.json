{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "accepted": {
      "type": "boolean",
      "const": true
    },
    "outcome": {
      "type": "string",
      "enum": [
        "enter",
        "classify"
      ]
    },
    "click_id": {
      "type": "string",
      "minLength": 1
    },
    "sublocation_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "job_key": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "accepted",
    "outcome",
    "click_id"
  ],
  "additionalProperties": false
}

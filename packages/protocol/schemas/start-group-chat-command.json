{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "world_id": {
      "type": "string",
      "minLength": 1
    },
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "member_ids": {
      "minItems": 2,
      "maxItems": 5,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    }
  },
  "required": [
    "world_id",
    "actor_id",
    "member_ids",
    "title",
    "request_id"
  ],
  "additionalProperties": false
}

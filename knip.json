{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["docs/**"],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": [
        "tests/**/*.test.ts",
        "tests/helpers/**/*.ts",
        "tests/fakes/**/*.ts",
        "tools/**/*.mjs"
      ],
      "project": ["tests/**/*.ts", "scripts/**/*.mjs", "tools/**/*.mjs"]
    },
    "packages/protocol": {
      "entry": ["scripts/*.mjs"],
      "project": ["src/**/*.ts", "scripts/*.mjs"]
    },
    "apps/server": {
      "entry": ["src/main.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["pino-pretty"]
    }
  }
}

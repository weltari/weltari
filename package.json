{
  "name": "weltari",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build --workspace @weltari/web",
    "typecheck": "tsc -b && tsc -p apps/web",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "protocol:emit": "node packages/protocol/scripts/emit.mjs",
    "knip": "knip",
    "gate": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run knip"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/eslint-plugin": "1.6.21",
    "better-sqlite3": "12.11.1",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-n": "18.2.1",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "knip": "6.24.0",
    "prettier": "3.9.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.10"
  }
}

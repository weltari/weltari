{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace", "@weltari/web"],
      "port": 5173
    },
    {
      "name": "weltari-masking",
      "runtimeExecutable": "powershell",
      "runtimeArgs": [
        "-NoProfile",
        "-Command",
        "$env:WELTARI_FAKE_LLM='1'; $env:WELTARI_FAKE_LLM_DELAY_MS='7000'; $env:WELTARI_DB_PATH=\"$env:TEMP\\weltari-mask\\w.sqlite\"; $env:WELTARI_IMAGES_DIR=\"$env:TEMP\\weltari-mask\\images\"; node apps/server/dist/main.js"
      ],
      "port": 7777
    }
  ]
}

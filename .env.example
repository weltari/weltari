# Names only — never commit values (Guide B15). Copy to .env (gitignored) or export in the shell.
# Port the Fastify server listens on (default 7777)
PORT=
# Listen address (default 127.0.0.1 — loopback only; Docker sets 0.0.0.0)
WELTARI_HOST=
# SQLite file location (default data/weltari.sqlite; parent dir is created)
WELTARI_DB_PATH=
# fatal|error|warn|info|debug|trace (default info)
LOG_LEVEL=
# OpenRouter API key — required unless WELTARI_FAKE_LLM=1
OPENROUTER_API_KEY=
# 1 = deterministic FakeLLM (kill harness, CI)
WELTARI_FAKE_LLM=
# FakeLLM first-token hold in ms — simulates the 5–10 s window the §1.14 masking covers
WELTARI_FAKE_LLM_DELAY_MS=
# Drop-in plugin folders directory (default plugins)
WELTARI_PLUGINS_DIR=
# 1 = print FAULT_POINT:<name> lines for the kill harness
WELTARI_EMIT_FAULT_POINTS=
# OpenRouter model id (default anthropic/claude-sonnet-4.5 — the criteria-proven config)
WELTARI_MODEL=
# GM-role model override (Rev 4 §16 model routing) — absent = WELTARI_MODEL; chat-class is plenty for the interview
WELTARI_GM_MODEL=
# Comma-separated OpenRouter provider.order pin (recommended: anthropic — cross-provider routing resets prompt caches)
WELTARI_PROVIDER_ORDER=
# Stable-prefix size in tokens for the fixture profile (criteria run: 50000)
WELTARI_PREFIX_TOKENS=
# Harness only: hold at fault points so SIGKILL lands inside the window (ms)
WELTARI_FAULT_PAUSE_MS=
# Job lease length in seconds (default 60; the kill harness shortens it)
WELTARI_LEASE_SECONDS=
# Chat idle timeout in minutes (default 30) — an untouched conversation closes and reflects
WELTARI_CHAT_IDLE_MINUTES=
# Proactive CRON DM cadence in GAME minutes (default 1440 = one per fictional day; 0 = off)
WELTARI_CRON_DM_GAME_MINUTES=
# Group-chat turn budget (default 3) — max character turns routed per user line
WELTARI_GROUP_TURN_BUDGET=
# Feed posts per GAME day (default 2; 0 = feed off) — max 10 per skip, freshest window survives
WELTARI_SOCIAL_POSTS_PER_DAY=
# Max recipients who get the ONE reaction decision per feed post (default 4)
WELTARI_SOCIAL_REACTION_CAP=
# Image pixels directory (default data/images) — rows/events hold path + hash
WELTARI_IMAGES_DIR=
# Painter tile source: stub (default; deterministic, free) | openrouter (real generation, needs OPENROUTER_API_KEY)
WELTARI_IMAGE_BACKEND=
# OpenRouter image model for the real painter backend (default google/gemini-3.1-flash-image, a.k.a. Nano Banana 2)
WELTARI_IMAGE_MODEL=
# Image model for Flow-A EDITS only (default google/gemini-3-pro-image, ~4x cost — flash-class never paints the drawn feature legibly)
WELTARI_EDIT_IMAGE_MODEL=
# OpenRouter multimodal model for the VLM seam — map QA, Flow B classification (default google/gemini-3.5-flash)
WELTARI_VLM_MODEL=
# Built frontend directory (default: web/dist resolved next to the compiled server)
WELTARI_WEB_DIR=
# Minisign public key (base64 body line) — ABSENT = self-update disabled (B12)
WELTARI_UPDATE_PUBKEY=
# 1 = notify-and-let-host-pull (Docker): check runs keyless, apply always 409s
WELTARI_UPDATE_NOTIFY_ONLY=
# Release channel URL (default: GitHub releases/latest for weltari/weltari)
WELTARI_UPDATE_RELEASES_URL=
# Version dirs + `current` pointer (default versions)
WELTARI_VERSIONS_DIR=
# Running-version override for the harness (default: server package.json version)
WELTARI_APP_VERSION=
# Cron pattern (UTC) for the periodic release check (default 0 8 * * *)
WELTARI_UPDATE_CHECK_CRON=
# Update artifact download cap in bytes (default 134217728)
WELTARI_UPDATE_MAX_BYTES=
# Telegram bot token — optional; absent = the Telegram connector stays stopped
TELEGRAM_BOT_TOKEN=
# Gauge cadence in ms (default 15000; the RSS criteria runner shortens it)
WELTARI_GAUGE_INTERVAL_MS=
